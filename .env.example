# Copy this file to .env and fill in your own secrets.
# NEVER commit .env to source control.

PORT=4000
NODE_ENV=development

# Generate strong random strings for production:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=replace_me_with_a_long_random_string
REFRESH_TOKEN_SECRET=replace_me_with_another_long_random_string

# MySQL database settings
DB_HOST=localhost
DB_PORT=3306
DB_USER=jwt_user
